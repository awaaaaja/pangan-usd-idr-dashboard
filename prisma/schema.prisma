model OutlierSummary {
  id                    String      @id @default(cuid())
  researchRunId         String      @map("research_run_id")
  sourceFile            String      @map("source_file")
  rowIndex              Int         @map("row_index")
  indikator             String
  jumlah                Int
  persentaseDariSampel  Float       @map("persentase_dari_sampel")
  researchRun           ResearchRun @relation(fields: [researchRunId], references: [id], onDelete: Cascade)

  @@unique([researchRunId, sourceFile, rowIndex], map: "outlier_summary_run_file_row_key")
  @@map("outlier_summary")
}

model OutlierDetail {
  id                                String      @id @default(cuid())
  researchRunId                     String      @map("research_run_id")
  sourceFile                        String      @map("source_file")
  rowIndex                          Int         @map("row_index")
  tanggal                           DateTime    @db.Date
  levelHarga                        String      @map("level_harga")
  provinsi                          String
  komoditas                         String
  hargaRupiah                       Float       @map("harga_rupiah")
  hargaBulanBerikutnya              Float       @map("harga_bulan_berikutnya")
  perubahanHarga1BulanPct           Float       @map("perubahan_harga_1_bulan_pct")
  targetPerubahanHarga1BulanPct     Float       @map("target_perubahan_harga_1_bulan_pct")
  nRawRows                          Int         @map("n_raw_rows")
  uniquePriceCount                  Int         @map("unique_price_count")
  minPrice                          Float       @map("min_price")
  maxPrice                          Float       @map("max_price")
  flagChangeAbs100Pct               Boolean     @map("flag_change_abs_100pct")
  flagTargetAbs100Pct               Boolean     @map("flag_target_abs_100pct")
  flagChangeMad                     Boolean     @map("flag_change_mad")
  flagTargetMad                     Boolean     @map("flag_target_mad")
  flagSourceConflict                Boolean     @map("flag_source_conflict")
  researchRun                       ResearchRun @relation(fields: [researchRunId], references: [id], onDelete: Cascade)

  @@unique([researchRunId, sourceFile, rowIndex], map: "outlier_detail_run_file_row_key")
  @@index([researchRunId, targetPerubahanHarga1BulanPct], map: "outlier_detail_run_target_idx")
  @@map("outlier_detail")
}

model OutlierSensitivity {
  id                       String      @id @default(cuid())
  researchRunId            String      @map("research_run_id")
  sourceFile               String      @map("source_file")
  rowIndex                 Int         @map("row_index")
  experiment               String
  skenario                 String
  n                        Int
  mae                      Float
  rmse                     Float
  r2                       Float
  smapePct                 Float       @map("smape_pct")
  medianAbsoluteError      Float       @map("median_absolute_error")
  bias                     Float
  directionalAccuracyPct   Float?      @map("directional_accuracy_pct")
  directionalN             Int         @map("directional_n")
  researchRun              ResearchRun @relation(fields: [researchRunId], references: [id], onDelete: Cascade)

  @@unique([researchRunId, sourceFile, rowIndex], map: "outlier_sensitivity_run_file_row_key")
  @@index([researchRunId, skenario], map: "outlier_sensitivity_run_scenario_idx")
  @@map("outlier_sensitivity")
}

model ShapGlobalImportance {
  id              String      @id @default(cuid())
  researchRunId   String      @map("research_run_id")
  sourceFile      String      @map("source_file")
  rowIndex        Int         @map("row_index")
  feature         String
  meanAbsShap     Float       @map("mean_abs_shap")
  kelompokFitur   String      @map("kelompok_fitur")
  researchRun     ResearchRun @relation(fields: [researchRunId], references: [id], onDelete: Cascade)

  @@unique([researchRunId, sourceFile, rowIndex], map: "shap_global_run_file_row_key")
  @@index([researchRunId, meanAbsShap], map: "shap_global_run_mean_idx")
  @@map("shap_global_importance")
}

model ShapGroupImportance {
  id              String      @id @default(cuid())
  researchRunId   String      @map("research_run_id")
  sourceFile      String      @map("source_file")
  rowIndex        Int         @map("row_index")
  kelompokFitur   String      @map("kelompok_fitur")
  meanAbsShap     Float       @map("mean_abs_shap")
  researchRun     ResearchRun @relation(fields: [researchRunId], references: [id], onDelete: Cascade)

  @@unique([researchRunId, sourceFile, rowIndex], map: "shap_group_run_file_row_key")
  @@map("shap_group_importance")
}

model ShapLocalObservation {
  id                                String      @id @default(cuid())
  researchRunId                     String      @map("research_run_id")
  sourceFile                        String      @map("source_file")
  rowIndex                          Int         @map("row_index")
  levelHarga                        String      @map("level_harga")
  kodeProvinsi                      String      @map("kode_provinsi")
  provinsi                          String
  komoditas                         String
  tanggal                           DateTime    @db.Date
  hargaRupiah                       Float       @map("harga_rupiah")
  usdIdrRataRataBulanan             Float       @map("usd_idr_rata_rata_bulanan")
  targetPerubahanHarga1BulanPct     Float       @map("target_perubahan_harga_1_bulan_pct")
  prediksi                          Float
  aktual                            Float
  absoluteError                     Float       @map("absolute_error")
  isSumateraBarat                   Boolean     @map("is_sumatera_barat")
  payload                           Json
  researchRun                       ResearchRun @relation(fields: [researchRunId], references: [id], onDelete: Cascade)

  @@unique([researchRunId, sourceFile, rowIndex], map: "shap_local_run_file_row_key")
  @@index([researchRunId, provinsi], map: "shap_local_run_provinsi_idx")
  @@map("shap_local_observation")
}
